{/* 内联以避免 FOUC（无样式内容闪烁）。这是一个解析器阻塞脚本。 */}
<script is:inline>
	const root = document.documentElement;
	const darkModePref = window.matchMedia("(prefers-color-scheme: dark)");

	function getUserPref() {
		const storedTheme = typeof localStorage !== "undefined" && localStorage.getItem("theme");
		return storedTheme || (darkModePref.matches ? "dark" : "light");
	}

	async function setTheme(newTheme) {
		if (newTheme !== "light" && newTheme !== "dark") {
			return console.warn(
				`Invalid theme value '${newTheme}' received. Expected 'light' or 'dark'.`,
			);
		}

		if (newTheme === root.getAttribute("data-theme")) {
			return;
		}

		root.setAttribute("data-theme", newTheme);
		await updateFavicon(newTheme);

		if (typeof localStorage !== "undefined") {
			localStorage.setItem("theme", newTheme);
		}
	}

	async function updateFavicon(theme) {
		const lightFavicon = document.getElementById("favicon-light");
		const darkFavicon = document.getElementById("favicon-dark");

		if (theme === "dark") {
			if (lightFavicon) lightFavicon.remove();
			if (darkFavicon) {
				darkFavicon.removeAttribute("media");
				darkFavicon.setAttribute("rel", "icon");
			} else {
				const newFavicon = document.createElement("link");
				newFavicon.id = "favicon-dark";
				newFavicon.rel = "icon";
				newFavicon.type = "image/svg+xml";
				newFavicon.href = "/icon-dark.svg";
				document.head.appendChild(newFavicon);
			}
		} else {
			if (darkFavicon) darkFavicon.remove();
			if (lightFavicon) {
				lightFavicon.removeAttribute("media");
				lightFavicon.setAttribute("rel", "icon");
			} else {
				const newFavicon = document.createElement("link");
				newFavicon.id = "favicon-light";
				newFavicon.rel = "icon";
				newFavicon.type = "image/svg+xml";
				newFavicon.href = "/icon-light.svg";
				document.head.appendChild(newFavicon);
			}
		}
	}

	// 初始设置 — 每次页面加载都执行
	(async () => {
		await setTheme(getUserPref());
	})();

	// is:inline 在 ClientRouter 切换时会重执行，用标记避免监听器累积
	if (!root.dataset.themeEvents) {
		root.dataset.themeEvents = "1";

		document.addEventListener("astro:after-swap", async () => {
			await setTheme(getUserPref());
		});

		document.addEventListener("theme-change", async (e) => {
			await setTheme(e.detail.theme);
		});

		darkModePref.addEventListener(
			"change",
			async (e) => await setTheme(e.matches ? "dark" : "light"),
		);
	}
</script>
