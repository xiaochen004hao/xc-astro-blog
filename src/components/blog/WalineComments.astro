---
import "@waline/client/style";
import "../../styles/waline-custom.css";
---

<div class="mt-6 border-t pt-8">
	<div id="waline"></div>
</div>

<script>
	const WALINE_SERVER = "https://waline.xc4h.qzz.io/";
	const VDITOR_CDN = "https://cdn.jsdelivr.net/npm/vditor@3.11.2/";

	let walineInstance: { destroy?: () => void } | null = null;
	let walineInitPromise: Promise<void> | null = null;
	let vditorInstance: any = null;
	let vditorObserver: MutationObserver | null = null;
	let themeObserver: MutationObserver | null = null;
	let submitListener: ((e: Event) => void) | null = null;

	function getCurrentTheme(): "light" | "dark" {
		return document.documentElement.getAttribute("data-theme") === "dark"
			? "dark"
			: "light";
	}

	function destroyAll() {
		if (vditorInstance) {
			try {
				vditorInstance.destroy?.();
			} catch {}
			vditorInstance = null;
		}
		if (vditorObserver) {
			vditorObserver.disconnect();
			vditorObserver = null;
		}
		if (themeObserver) {
			themeObserver.disconnect();
			themeObserver = null;
		}
		if (submitListener) {
			document.removeEventListener("click", submitListener, true);
			submitListener = null;
		}
		if (walineInstance?.destroy) {
			walineInstance.destroy();
			walineInstance = null;
		}
		const el = document.getElementById("waline");
		if (el) el.innerHTML = "";
	}

	function preloadVditorCss() {
		if (document.querySelector('link[data-vditor-css]')) return;
		const link = document.createElement("link");
		link.rel = "stylesheet";
		link.href = `${VDITOR_CDN}dist/index.css`;
		link.setAttribute("data-vditor-css", "");
		document.head.appendChild(link);
	}

	async function initVditor(textarea: HTMLTextAreaElement) {
		if (vditorInstance) return;

		preloadVditorCss();

		const { default: Vditor } = await import("vditor");

		if (vditorInstance) return;

		const container = document.createElement("div");
		container.className = "wl-vditor-wrapper";
		textarea.insertAdjacentElement("afterend", container);

		textarea.style.display = "none";
		textarea.setAttribute("aria-hidden", "true");

		const theme = getCurrentTheme();

		vditorInstance = new Vditor(container, {
			height: 240,
			minHeight: 180,
			mode: "ir",
			theme: theme === "dark" ? "dark" : "classic",
			cdn: VDITOR_CDN,
			toolbar: [
				"emoji",
				"headings",
				"bold",
				"italic",
				"|",
				"link",
				"list",
				"ordered-list",
				"check",
				"quote",
				"line",
				"|",
				"code",
				"inline-code",
				"|",
				"undo",
				"redo",
				"|",
				"edit-mode",
				"preview",
				"fullscreen",
			],
			toolbarConfig: { pin: true },
			cache: { enable: false },
			counter: { enable: true, type: "markdown", max: 2000 },
			placeholder: "支持 Markdown 语法，说点什么吧…",
			preview: { delay: 300, hljs: { style: theme === "dark" ? "github-dark" : "github" } },
			comment: { enable: false },
			hint: { emojiPath: `${VDITOR_CDN}dist/images/emoji/` },
			input: (value: string) => {
				textarea.value = value;
			},
			after: () => {
				if (textarea.value) {
					vditorInstance?.setValue?.(textarea.value);
				}
			},
		});

		themeObserver = new MutationObserver(() => {
			if (!vditorInstance) return;
			const newTheme = getCurrentTheme();
			try {
				vditorInstance.setTheme?.(
					newTheme === "dark" ? "dark" : "classic",
					newTheme === "dark" ? "dark" : "classic",
					newTheme === "dark" ? "github-dark" : "github",
				);
			} catch {}
		});
		themeObserver.observe(document.documentElement, {
			attributes: true,
			attributeFilter: ["data-theme"],
		});

		submitListener = (e: Event) => {
			const target = e.target as HTMLElement;
			if (target.classList?.contains("wl-btn") && target.classList.contains("primary")) {
				setTimeout(() => {
					if (vditorInstance && !textarea.value) {
						vditorInstance.setValue?.("");
					}
				}, 600);
			}
		};
		document.addEventListener("click", submitListener, true);
	}

	function watchForEditor() {
		const existing = document.querySelector<HTMLTextAreaElement>(".wl-editor");
		if (existing) {
			initVditor(existing);
			return;
		}
		vditorObserver = new MutationObserver(() => {
			const textarea = document.querySelector<HTMLTextAreaElement>(".wl-editor");
			if (textarea && !vditorInstance) {
				vditorObserver?.disconnect();
				vditorObserver = null;
				initVditor(textarea);
			}
		});
		vditorObserver.observe(document.getElementById("waline") || document.body, {
			childList: true,
			subtree: true,
		});
	}

	async function walineInit() {
		const el = document.getElementById("waline");
		if (!el) return;

		if (!walineInitPromise) {
			walineInitPromise = import("@waline/client")
				.then(({ init }) => {
					walineInstance = init({
						el: "#waline",
						serverURL: WALINE_SERVER,
						path: window.location.pathname,
						lang: "zh-CN",
						dark: '[data-theme="dark"]',
						emoji: ["//unpkg.com/@waline/emojis@latest/weibo"],
						meta: ["nick", "mail", "link"],
						requiredMeta: ["nick"],
						pageSize: 10,
					});
					setTimeout(watchForEditor, 100);
				})
				.finally(() => {
					walineInitPromise = null;
				});
		}

		await walineInitPromise;
	}

	document.addEventListener("astro:before-swap", destroyAll);
	document.addEventListener("astro:page-load", walineInit);
</script>
