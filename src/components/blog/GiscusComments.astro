---
const {
	repo = "xiaochen004hao/xc-astro-blog",
	repoId = "R_kg_DOOK_ENTER_YOUR_REPO_ID_HERE",
	category = "General",
	categoryId = "DIC_kw_DOOK_ENTER_YOUR_CATEGORY_ID_HERE",
} = Astro.props as {
	repo?: string;
	repoId?: string;
	category?: string;
	categoryId?: string;
};
---

<div class="mt-16 border-t pt-8">
	<h2 class="mb-6 text-lg font-semibold tracking-wide">评论</h2>
	<script
		is:inline
		src="https://giscus.app/client.js"
		data-repo={repo}
		data-repo-id={repoId}
		data-category={category}
		data-category-id={categoryId}
		data-mapping="pathname"
		data-strict="0"
		data-reactions-enabled="1"
		data-emit-metadata="0"
		data-input-position="top"
		data-theme="preferred_color_scheme"
		data-lang="zh-CN"
		data-loading="lazy"
		crossorigin="anonymous"
		async
	></script>
</div>
