---
const { title, url } = Astro.props as {
	title: string;
	url: string;
};
---

<div class="mt-10 flex items-center gap-3">
	<button
		type="button"
		class="text-muted hover:text-accent inline-flex items-center gap-1.5 border px-3 py-1.5 text-xs font-medium transition-colors cursor-pointer"
		data-share
		data-title={title}
		data-url={url}
	>
		<svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
			<path stroke-linecap="round" stroke-linejoin="round" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z" />
		</svg>
		<span class="share-text">分享</span>
	</button>
</div>

<script>
	function bindShareButtons() {
		document.querySelectorAll<HTMLButtonElement>("button[data-share]").forEach((btn) => {
			btn.addEventListener("click", async () => {
				const title = btn.dataset.title || document.title;
				const pageUrl = btn.dataset.url || window.location.href;

				if (navigator.share) {
					try {
						await navigator.share({
							title,
							url: pageUrl,
						});
						return;
					} catch {
						// User cancelled or error, do nothing
					}
				}

				// Fallback: copy to clipboard
				try {
					await navigator.clipboard.writeText(pageUrl);
					const textEl = btn.querySelector(".share-text");
					const orig = textEl?.textContent;
					if (textEl) {
						textEl.textContent = "已复制!";
						setTimeout(() => {
							textEl.textContent = orig || "分享";
						}, 1500);
					}
				} catch {
					// Silent fail
				}
			});
		});
	}

	bindShareButtons();
	document.addEventListener("astro:page-load", bindShareButtons);
</script>
