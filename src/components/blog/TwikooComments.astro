---
const { envId = "https://twikoo-comments.qoslzm.dpdns.org/" } = Astro.props as {
	envId?: string;
};
---

<div class="mt-16 border-t pt-8">
	<h2 class="mb-6 text-lg font-semibold tracking-wide">评论</h2>
	<div id="twikoo-comments"></div>
</div>

<script is:inline define:vars={{ envId }}>
	(function () {
		if (envId.startsWith("https://your-twikoo")) return;

		var script = document.createElement("script");
		script.src = "https://cdn.jsdelivr.net/npm/twikoo@1.7.4/dist/twikoo.all.min.js";
		script.crossOrigin = "anonymous";
		script.onload = function () {
			window.twikoo &&
				window.twikoo.init({
					envId: envId,
					el: "#twikoo-comments",
					path: window.location.pathname,
					lang: "zh-CN",
				});
		};
		document.body.appendChild(script);
	})();
</script>
