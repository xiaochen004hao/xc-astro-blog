---
import type { MarkdownHeading } from "astro";
import { generateToc } from "@/utils/generateToc";
import TOCHeading from "./TOCHeading.astro";

interface Props {
	headings: MarkdownHeading[];
	title?: string;
}

const { headings, title } = Astro.props;

const toc = generateToc(headings);

if (title) {
	toc.unshift({
		depth: 0,
		slug: "blog-title",
		text: title,
		children: [],
	});
}
---

<details
	class="toc-details group lg:sticky lg:top-12 lg:order-2 lg:-me-32 lg:basis-64"
	id="toc-details"
>
	<summary class="title hover:marker:text-accent cursor-pointer text-lg">目录</summary>
	<nav class="ms-4 lg:w-full">
		<ol class="mt-4">
			{toc.map((heading) => <TOCHeading heading={heading} />)}
		</ol>
	</nav>
</details>
<script>
	function tocEnsureOpen() {
		const el = document.getElementById("toc-details") as HTMLDetailsElement | null;
		if (el && window.matchMedia("(min-width: 1024px)").matches) {
			el.open = true;
		}
	}
	tocEnsureOpen();
	document.addEventListener("astro:page-load", tocEnsureOpen);
</script>
