---
import PageLayout from "@/layouts/Base.astro";

interface Friend {
    name: string;
    url: string;
    description: string;
    avatar?: string;
}

const friends: Friend[] = [
];

const meta = {
    title: "友人",
    description: "友情链接 - 朋友们",
};
---

<PageLayout meta={meta}>
    <article class="prose prose-sm prose-cactus max-w-none">
        <h1>友人</h1>
        <p class="lead">
            这里是一些朋友们的博客和网站。欢迎交换友链。
        </p>
        {
            friends.length > 0 ? (
                <div class="not-prose mt-8 grid grid-cols-1 gap-4 sm:grid-cols-2">
                    {friends.map((friend) => (
                        <a
                            href={friend.url}
                            target="_blank"
                            rel="noopener noreferrer me"
                            class="group hover:border-accent flex items-center gap-4 border p-4 transition-colors"
                        >
                            <div class="bg-muted/20 flex h-12 w-12 shrink-0 items-center justify-center text-lg font-bold">
                                {friend.avatar ?? friend.name.charAt(0)}
                            </div>
                            <div class="min-w-0">
                                <p class="group-hover:text-accent truncate text-sm font-medium transition-colors">
                                    {friend.name}
                                </p>
                                <p class="text-muted truncate text-xs">
                                    {friend.description}
                                </p>
                            </div>
                        </a>
                    ))}
                </div>
            ) : (
                <div class="text-muted mt-8 py-16 text-center">
                    <p class="text-lg">暂时还没有添加友链</p>
                    <p class="mt-2 text-sm">如果你有博客想要交换，欢迎联系我！</p>
                </div>
            )
        }
        {
            friends.length > 0 && (
                <div class="text-muted mt-12 border-t pt-6 text-sm">
                    <h2 class="text-global-text text-base font-semibold">交换友链</h2>
                    <p class="mt-2">
                        想要交换友链？请确保你的网站内容质量良好、长期更新，然后通过
                        <a href="https://github.com/xiaochen004hao/xc-astro-blog/issues" class="cactus-link">GitHub Issues</a>
                        联系我，附上你的网站名称、链接和简介。
                    </p>
                </div>
            )
        }
    </article>
</PageLayout>
