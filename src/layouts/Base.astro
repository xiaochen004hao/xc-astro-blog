---
import { ClientRouter } from "astro:transitions";
import BaseHead from "@/components/BaseHead.astro";
import Footer from "@/components/layout/Footer.astro";
import Header from "@/components/layout/Header.astro";
import SkipLink from "@/components/SkipLink.astro";
import ThemeProvider from "@/components/ThemeProvider.astro";
import { siteConfig } from "@/site.config";
import type { SiteMeta } from "@/types";

interface Props {
	meta: SiteMeta;
}

const {
	meta: { articleDate, description = siteConfig.description, ogImage, title },
} = Astro.props;
---

<html class="scroll-smooth" lang={siteConfig.lang}>
	<head>
		<BaseHead articleDate={articleDate} description={description} ogImage={ogImage} title={title} />
		<ClientRouter />
		<ThemeProvider />
	</head>
	<body
		class="bg-global-bg text-global-text mx-auto flex min-h-screen max-w-3xl flex-col px-4 pt-16 font-sans text-sm font-normal antialiased sm:px-8"
	>
		<script is:inline>
			document.querySelectorAll(":root > *:not(head):not(body)").forEach(function (el) {
				el.style.display = "none";
			});
		</script>
		<div
			id="reading-progress"
			class="bg-accent pointer-events-none fixed top-0 left-0 z-100 h-0.5 w-0 transition-[width] duration-150 ease-out"
		>
		</div>
		<SkipLink />
		<Header />

		<!-- SW 更新提示（默认隐藏） -->
		<div
			id="sw-update-banner"
			class="border-global-bg/20 fixed bottom-6 left-1/2 z-50 hidden -translate-x-1/2 border px-4 py-3 shadow-lg backdrop-blur-sm"
			style="background-color: color-mix(in oklch, var(--color-global-bg) 95%, transparent);"
		>
			<div class="flex items-center gap-3">
				<span class="text-sm" style="color: var(--color-global-text);">检测到新版本可用</span>
				<button
					id="sw-update-button"
					class="px-3 py-1 text-sm font-medium transition-colors hover:opacity-80"
					style="background-color: var(--color-accent); color: var(--color-global-bg);">更新</button
				>
				<button
					id="sw-dismiss-button"
					class="text-sm transition-colors hover:opacity-70"
					style="color: var(--color-muted);">稍后</button
				>
			</div>
		</div>
		<main id="main">
			<slot />
		</main>
		<Footer />

		<script>
			import "@/scripts/lenis.ts";
		</script>

		<script>
			import "@/scripts/progress-bar.ts";
		</script>

		<script>
			import "@/scripts/medium-zoom.ts";
		</script>

		<script is:inline>
			(function initLoading() {
				const KEY = "xc-loaded";
				if (sessionStorage.getItem(KEY)) return;

				const style = document.createElement("style");
				style.textContent = `@keyframes xc-pulse{0%,100%{opacity:.65;transform:scale(1)}50%{opacity:1;transform:scale(1.06)}}`;
				document.head.appendChild(style);

				const el = document.createElement("div");
				el.id = "xc-loading";
				Object.assign(el.style, {
					position: "fixed",
					inset: "0",
					zIndex: "10000",
					display: "flex",
					alignItems: "center",
					justifyContent: "center",
					flexDirection: "column",
					background: "var(--color-global-bg)",
					transition: "opacity 0.4s ease-out",
				});
				el.innerHTML = `<svg aria-hidden="true" style="width:88px;height:88px;animation:xc-pulse 1.6s ease-in-out infinite" fill="none" xmlns="http://www.w3.org/2000/svg" viewBox="-2 -2 28 28"><rect x="-2" y="-2" width="28" height="28" fill="var(--color-logo-bg)"/><path fill="var(--color-logo-text)" d="M3 4 h6 v6 h6 v-6 h6 v6 h-6 v3 h3 v8 h-3 v-3 h-6 v3 h-3 v-8 h3 v-3 h-6 z"/></svg>`;
				document.body.prepend(el);
				document.body.style.overflow = "hidden";

				let done = false;
				const minMs = 1400;
				const maxMs = 6000;
				const started = Date.now();

				function hide() {
					if (done) return;
					done = true;
					const elapsed = Date.now() - started;
					const wait = Math.max(0, minMs - elapsed);
					setTimeout(() => {
						el.style.opacity = "0";
						setTimeout(() => {
							el.remove();
							style.remove();
							document.body.style.overflow = "";
							sessionStorage.setItem(KEY, "1");
						}, 420);
					}, wait);
				}

				window.addEventListener("load", hide);
				setTimeout(hide, maxMs);
			})();
		</script>

		<script is:inline>
			if (!document.documentElement.dataset.swapEvents) {
				document.documentElement.dataset.swapEvents = "1";
				document.addEventListener("astro:before-swap", () => {
					document.documentElement.style.overflow = "hidden";
				});
				document.addEventListener("astro:page-load", () => {
					document.documentElement.style.overflow = "";
				});
			}
		</script>

		<script>
			if (typeof window !== "undefined" && "serviceWorker" in navigator && !window.__swReady) {
				window.__swReady = true;

				const BANNER_KEY = "xc-sw-dismissed";

				const showUpdateBanner = () => {
					if (sessionStorage.getItem(BANNER_KEY)) return;
					document.getElementById("sw-update-banner")?.classList.remove("hidden");
				};

				const hideUpdateBanner = () => {
					sessionStorage.setItem(BANNER_KEY, "1");
					document.getElementById("sw-update-banner")?.classList.add("hidden");
				};

				const updateAndReload = () => {
					hideUpdateBanner();
					navigator.serviceWorker
						.getRegistration()
						.then((reg) => {
							if (reg) {
								reg.unregister();
							}
						})
						.then(() => {
							sessionStorage.removeItem(BANNER_KEY);
							window.location.reload();
						})
						.catch(() => {
							window.location.reload();
						});
				};

				navigator.serviceWorker
					.register("/service-worker.js")
					.then((reg) => {
						reg.addEventListener("updatefound", () => {
							const newWorker = reg.installing;
							if (!newWorker) return;
							newWorker.addEventListener("statechange", () => {
								if (newWorker.state === "installed" && navigator.serviceWorker.controller) {
									showUpdateBanner();
								}
							});
						});

						if (reg.waiting && navigator.serviceWorker.controller) {
							showUpdateBanner();
						}
					})
					.catch(() => {});

				document.addEventListener("click", (e) => {
					const target = e.target as HTMLElement;
					if (target.id === "sw-update-button") updateAndReload();
					if (target.id === "sw-dismiss-button") hideUpdateBanner();
				});
			}
		</script>
	</body>
</html>
