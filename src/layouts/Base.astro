---
import { ClientRouter } from "astro:transitions";
import BaseHead from "@/components/BaseHead.astro";
import Footer from "@/components/layout/Footer.astro";
import Header from "@/components/layout/Header.astro";
import SkipLink from "@/components/SkipLink.astro";
import ThemeProvider from "@/components/ThemeProvider.astro";
import { siteConfig } from "@/site.config";
import type { SiteMeta } from "@/types";

interface Props {
	meta: SiteMeta;
}

const {
	meta: { articleDate, description = siteConfig.description, ogImage, title },
} = Astro.props;
---

<html class="scroll-smooth" lang={siteConfig.lang}>
	<head>
		<BaseHead articleDate={articleDate} description={description} ogImage={ogImage} title={title} />
		<ClientRouter />
		<ThemeProvider />
		<script type="module" src="../scripts/lenis.js"></script>
		<script type="module" src="../scripts/sw-update.js"></script>
	</head>
	<body
		class="bg-global-bg text-global-text mx-auto flex min-h-screen max-w-3xl flex-col px-4 pt-16 font-mono text-sm font-normal antialiased sm:px-8"
	>
		<SkipLink />
		<Header />

		<!-- SW 更新提示（默认隐藏） -->
		<div id="sw-update-banner" class="hidden fixed bottom-6 left-1/2 -translate-x-1/2 z-50">
			<div class="flex items-center gap-3 rounded-lg bg-zinc-200 px-3 py-2 shadow dark:bg-zinc-800">
				<span class="text-sm">检测到新版本可用</span>
				<button id="sw-update-button" class="ml-2 rounded bg-accent px-3 py-1 text-sm text-white">更新</button>
				<button id="sw-dismiss-button" class="ml-2 text-sm text-muted">稍后</button>
			</div>
		</div>
		<main id="main">
			<slot />
		</main>
		<Footer />

		<script is:inline>
			(() => {
				const banner = document.getElementById('sw-update-banner');
				const updateBtn = document.getElementById('sw-update-button');
				const dismissBtn = document.getElementById('sw-dismiss-button');
				const show = () => banner?.classList.remove('hidden');
				const hide = () => banner?.classList.add('hidden');

				window.addEventListener('sw:updateAvailable', () => {
					show();
				});

				// 如果 sw-update 已在 head 中设置了全局标志，立即显示
				if ((window).__sw_update_available) show();

				updateBtn?.addEventListener('click', () => {
					if (typeof window.__sw_update_activate === 'function') {
						window.__sw_update_activate();
					} else {
						navigator.serviceWorker.getRegistration().then((reg) => reg?.waiting?.postMessage({ type: 'SKIP_WAITING' }));
					}
				});

				dismissBtn?.addEventListener('click', hide);
			})();
		</script>
		<script is:inline type="speculationrules">
			{
				"prefetch": [
					{
						"where": {
							"href_matches": "/*"
						},
						"eagerness": "immediate"
					}
				],
				"prerender": [
					{
						"where": {
							"href_matches": "/*"
						},
						"eagerness": "moderate"
					}
				]
			}
		</script>
	</body>
</html>
