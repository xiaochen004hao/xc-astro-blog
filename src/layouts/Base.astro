---
import { ClientRouter } from "astro:transitions";
import BaseHead from "@/components/BaseHead.astro";
import Footer from "@/components/layout/Footer.astro";
import Header from "@/components/layout/Header.astro";
import SkipLink from "@/components/SkipLink.astro";
import ThemeProvider from "@/components/ThemeProvider.astro";
import { siteConfig } from "@/site.config";
import type { SiteMeta } from "@/types";

interface Props {
	meta: SiteMeta;
}

const {
	meta: { articleDate, description = siteConfig.description, ogImage, title },
} = Astro.props;
---

<html class="scroll-smooth" lang={siteConfig.lang}>
	<head>
		<BaseHead articleDate={articleDate} description={description} ogImage={ogImage} title={title} />
		<ClientRouter />
		<ThemeProvider />
	</head>
	<body
		class="bg-global-bg text-global-text mx-auto flex min-h-screen max-w-3xl flex-col px-4 pt-16 font-sans text-sm font-normal antialiased sm:px-8"
	>
		<SkipLink />
		<Header />

		<!-- SW 更新提示（默认隐藏） -->
		<div
			id="sw-update-banner"
			class="border-global-bg/20 fixed bottom-6 left-1/2 z-50 hidden -translate-x-1/2 rounded-lg border px-4 py-3 shadow-lg backdrop-blur-sm"
			style="background-color: color-mix(in oklch, var(--color-global-bg) 95%, transparent);"
		>
			<div class="flex items-center gap-3">
				<span class="text-sm" style="color: var(--color-global-text);">检测到新版本可用</span>
				<button
					id="sw-update-button"
					class="rounded px-3 py-1 text-sm font-medium transition-colors hover:opacity-80"
					style="background-color: var(--color-accent); color: var(--color-global-bg);">更新</button
				>
				<button
					id="sw-dismiss-button"
					class="text-sm transition-colors hover:opacity-70"
					style="color: var(--color-muted);">稍后</button
				>
			</div>
		</div>
		<main id="main">
			<slot />
		</main>
		<Footer />

		<script>
			import "@/scripts/lenis.ts";
		</script>

		<script>
			if (typeof window !== "undefined" && "serviceWorker" in navigator) {
				let updatePending = false;
				let swRegistration = null;

				const showUpdateBanner = () => {
					if (updatePending) return;
					updatePending = true;
					const banner = document.getElementById("sw-update-banner");
					if (banner) banner.classList.remove("hidden");
				};

				const hideUpdateBanner = () => {
					updatePending = false;
					const banner = document.getElementById("sw-update-banner");
					if (banner) banner.classList.add("hidden");
				};

				const activateWaitingSW = () => {
					if (swRegistration?.waiting) {
						swRegistration.waiting.postMessage({ type: "SKIP_WAITING" });
					}
					hideUpdateBanner();
				};

				const checkForUpdates = () => {
					if (!swRegistration) return;
					swRegistration.update().catch(() => {});
					if (swRegistration.waiting && updatePending === false) {
						showUpdateBanner();
					}
				};

				navigator.serviceWorker
					.register("/service-worker.js")
					.then((reg) => {
						swRegistration = reg;

						reg.addEventListener("updatefound", () => {
							const newWorker = reg.installing;
							if (!newWorker) return;
							newWorker.addEventListener("statechange", () => {
								if (newWorker.state === "installed" && navigator.serviceWorker.controller) {
									showUpdateBanner();
								}
							});
						});

						navigator.serviceWorker.addEventListener("controllerchange", () => {
							if (updatePending) {
								window.location.reload();
							}
						});

						if (reg.waiting) {
							showUpdateBanner();
						}

						setTimeout(() => {
							checkForUpdates();
							setInterval(checkForUpdates, 60000);
						}, 3000);
					})
					.catch(() => {});

				document.addEventListener("click", (e) => {
					const target = e.target as HTMLElement;
					if (target.id === "sw-update-button") activateWaitingSW();
					if (target.id === "sw-dismiss-button") hideUpdateBanner();
				});
			}
		</script>
		<script is:inline type="speculationrules">
			{
				"prefetch": [
					{
						"where": {
							"href_matches": "/*"
						},
						"eagerness": "moderate"
					}
				],
				"prerender": [
					{
						"where": {
							"href_matches": "/*"
						},
						"eagerness": "conservative"
					}
				]
			}
		</script>
	</body>
</html>
